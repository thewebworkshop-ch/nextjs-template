{
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":gitSignOff",
    ":semanticCommits",
    "mergeConfidence:all-badges"
  ],
  "ignoreUnstable": true,
  "labels": ["dependencies"],
  "schedule": ["before 7am on monday"],
  "timezone": "Europe/Zurich",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "rebaseWhen": "behind-base-branch",
  "automerge": false,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "automerge"],
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 7am on monday"],
    "labels": ["automerge"]
  },
  "packageRules": [
    {
      "description": "Group Docker updates",
      "matchManagers": ["dockerfile"],
      "groupName": "docker",
      "pinDigests": true,
      "matchUpdateTypes": ["patch", "minor", "pin", "digest", "pinDigest"],
      "labels": ["automerge"]
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "matchUpdateTypes": ["patch", "minor", "pin", "digest", "pinDigest"],
      "labels": ["automerge"]
    },
    {
      "description": "Group Node.js updates",
      "matchDepNames": ["node"],
      "groupName": "node",
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["automerge"]
    },
    {
      "description": "pnpm packageManager: automerge patches and minors after 7 days",
      "matchDepTypes": ["packageManager"],
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["automerge"]
    },
    {
      "description": "Group Next.js and React ecosystem (App Router strict compatibility)",
      "matchPackageNames": [
        "next",
        "eslint-config-next",
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ],
      "groupName": "nextjs-react-ecosystem"
    },
    {
      "description": "Group Tailwind CSS v4 ecosystem",
      "matchPackageNames": [
        "tailwindcss",
        "@tailwindcss/postcss",
        "prettier-plugin-tailwindcss"
      ],
      "groupName": "tailwindcss-ecosystem"
    },
    {
      "description": "Group Prisma packages (client + schema must match)",
      "groupName": "prisma",
      "matchPackageNames": ["@prisma/**", "prisma"]
    },
    {
      "description": "Group Playwright packages (test runner + browsers)",
      "groupName": "playwright",
      "matchPackageNames": [
        "@playwright/**",
        "playwright",
        "@axe-core/playwright"
      ]
    },
    {
      "description": "Security updates: high priority",
      "matchDepTypes": ["dependencies", "devDependencies"],
      "matchUpdateTypes": ["patch", "minor", "major"],
      "matchCategories": ["security"],
      "prPriority": 10
    },
    {
      "description": "Default: wait 7 days before creating PR (badges stabilize)",
      "matchPackageNames": ["*"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Major updates: require dashboard approval (14-day delay for community vetting)",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Production minor: require dashboard approval (7-day delay for badge stabilization)",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "dependencyDashboardApproval": true,
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Dev dependencies minor/patch: automerge via Mergify",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["automerge"]
    },
    {
      "description": "Production deps: patch after 14 days, automerge via Mergify",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "14 days",
      "labels": ["automerge"]
    },
    {
      "description": "Show both Merge Confidence and OpenSSF Scorecard badges",
      "matchSourceUrls": ["https://github.com/**"],
      "prBodyColumns": [
        "Package",
        "Type",
        "Update",
        "Change",
        "Age",
        "Adoption",
        "Passing",
        "Confidence",
        "OpenSSF"
      ],
      "prBodyDefinitions": {
        "OpenSSF": "[![OpenSSF Scorecard](https://api.securityscorecards.dev/projects/github.com/{{sourceRepo}}/badge)](https://securityscorecards.dev/viewer/?uri=github.com/{{sourceRepo}})"
      }
    }
  ]
}
